{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ax/report",
  "title": ".work AX report manifest (front-matter the renderer reads)",
  "type": "object",
  "required": ["subjectId", "profileRef"],
  "properties": {
    "subjectId": { "type": "string" },
    "generatedBy": { "type": "string", "default": "agent-ergonomics" },
    "mode": { "enum": ["harness-agnostic", "harness-specific"] },
    "profileRef": { "type": "string" },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cell": { "type": "string" },
          "priority": { "type": "integer" },
          "title": { "type": "string" },
          "rationale": { "type": "string" },
          "patch": { "type": "string", "description": "unified diff when mechanical" },
          "evidence": { "type": "array" }
        }
      }
    }
  }
}
