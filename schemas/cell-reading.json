{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ax/cell-reading",
  "title": "One matrix cell reading",
  "type": "object",
  "required": ["surface", "lens", "instrument", "normalized"],
  "properties": {
    "surface": { "enum": ["disclosure", "interface", "loop", "recursion", "human"] },
    "lens": { "enum": ["coherence", "economy", "determinism", "verifiability", "prior_alignment", "safety"] },
    "instrument": { "enum": ["telemetry", "counters", "perplexity", "elo", "irt", "trajectory", "pareto", "friction"] },
    "raw": { "description": "instrument-native value (number/object)" },
    "normalized": { "type": "number", "minimum": -1, "maximum": 1, "description": "comparable across tools; hostile is negative" },
    "level": { "enum": ["hostile", "absent", "tolerable", "good", "exemplary"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "n": { "type": "integer" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "ref"],
        "properties": {
          "type": { "enum": ["source", "probe-log"] },
          "ref": { "type": "string", "description": "file:line(-line) or runId" },
          "hash": { "type": "string", "description": "integrity hash of cited lines" },
          "excerpt": { "type": "string" }
        }
      }
    }
  }
}
