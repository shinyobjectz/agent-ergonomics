{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ax/probe",
  "title": "Probe definition",
  "type": "object",
  "required": ["tier", "id"],
  "properties": {
    "id": { "type": "string" },
    "tier": { "enum": ["T0", "T1", "T2", "T3", "T4", "T5", "T6", "static"] },
    "intentTemplate": { "type": "string", "description": "constant across tools; bound to subject for content" },
    "measures": { "type": "array", "items": { "type": "string" }, "description": "cell ids this probe feeds" },
    "n": { "type": "integer", "default": 5 },
    "params": { "type": "object", "additionalProperties": true }
  }
}
