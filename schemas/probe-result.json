{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ax/probe-result",
  "title": "Raw signals from running a probe",
  "type": "object",
  "required": ["probeId", "subjectId", "tier", "runs"],
  "properties": {
    "probeId": { "type": "string" },
    "subjectId": { "type": "string" },
    "tier": { "type": "string" },
    "agent": { "type": "string", "description": "workagent | <harness>" },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "runId": { "type": "string" },
          "success": { "type": "boolean" },
          "turns": { "type": "integer" },
          "tokensIn": { "type": "integer" },
          "tokensOut": { "type": "integer" },
          "retries": { "type": "integer" },
          "timeToFirstActionMs": { "type": "number" },
          "wallMs": { "type": "number" },
          "exit": { "type": "integer" },
          "artifacts": { "type": "array", "items": { "type": "string" } },
          "transcriptRef": { "type": "string" },
          "perTurn": { "type": "array", "items": { "type": "object", "properties": { "turn": {"type":"integer"}, "tokens": {"type":"integer"}, "compactionLevel": {"type":"integer"}, "goalProgress": {"type":"number"} } } },
          "extra": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}
